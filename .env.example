DATABASE_URL=postgresql+psycopg2://<db-user>:<db-password>@<db-host>:5432/bakemanage
CELERY_BROKER_URL=redis://<redis-host>:6379/0
CELERY_RESULT_BACKEND=redis://<redis-host>:6379/0
REDIS_URL=redis://<redis-host>:6379/0
ENVIRONMENT=development

# ── Auth & Security ───────────────────────────────────────────────────────────
# JWT_SECRET: generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit a real value. Inject at runtime via Vault or GitHub Secrets.
JWT_SECRET=<generate-with-secrets.token_hex-32>
JWT_EXPIRY_MINUTES=30

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# DEFAULT_ADMIN_USERNAME: email/username of the seeded admin account
DEFAULT_ADMIN_USERNAME=<admin-email-or-username>
# DEFAULT_ADMIN_PIN: numeric PIN for the bootstrap admin. Inject via Vault or GitHub Secrets.
DEFAULT_ADMIN_PIN=<your-admin-pin>
# BOOTSTRAP_PIN: PIN used by CI/integration tests — keep in sync with DEFAULT_ADMIN_PIN
BOOTSTRAP_PIN=<your-bootstrap-pin>

# ── Fernet Encryption ─────────────────────────────────────────────────────────
# Auto-derived from JWT_SECRET when unset. Override only if you manage keys externally.
# FERNET_KEY=<base64-urlsafe-32-byte-key>

# ── Olympus Platform Integration ──────────────────────────────────────────────
# Set these when deploying to the Olympus.ai platform (post-May on-prem).
# Leave blank or commented during cloud-first development.
OLYMPUS_APP_NAME=bakemanage
# VAULT_ADDR=https://vault.olympus.ai
# VAULT_TOKEN=<injected-at-runtime>
# DIPLOMAT_URL=http://diplomat.olympus.ai:8000
# SSO_ENFORCE=false

# ── Google AI Studio (Gemini) ─────────────────────────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey
# When set, real Gemini VLM is used for invoice OCR instead of the stub.
# GAIS_BM_APIK=<your-gemini-api-key>
